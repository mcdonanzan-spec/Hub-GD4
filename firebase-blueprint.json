{
  "entities": {
    "DataSnapshot": {
      "title": "DataSnapshot",
      "description": "Registro de importação de planilha (Empresas ou Colaboradores) com dados brutos.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["COMPANY_DOCS", "EMPLOYEE_DOCS"] },
        "referenceMonth": { "type": "string", "description": "Formato YYYY-MM" },
        "importDate": { "type": "string", "format": "date-time" },
        "worksite": { "type": "string" },
        "contractorName": { "type": "string" },
        "cnpj": { "type": "string" },
        "rawData": { "type": "object", "description": "Objeto contendo todas as colunas da planilha" },
        "status": { "type": "string" },
        "importedBy": { "type": "string" }
      },
      "required": ["type", "referenceMonth", "importDate", "rawData", "importedBy"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Compromisso na agenda digital.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["VISITA", "REUNIAO", "REGULARIZACAO", "AUDITORIA"] },
        "worksite": { "type": "string" },
        "contractorId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["PLANEJADO", "REALIZADO", "CANCELADO"] },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "date", "type", "status", "createdBy"]
    }
  },
  "firestore": {
    "/snapshots/{snapshotId}": {
      "schema": "DataSnapshot",
      "description": "Coleção de dados históricos importados das planilhas GD4."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Coleção de compromissos da agenda."
    }
  }
}
