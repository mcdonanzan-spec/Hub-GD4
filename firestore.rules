rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: contractors
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - status: string (required, enum: APTO, BLOQUEADO, PENDENTE)
    //   - worksite: string (required)
    //   - cnpj: string (optional)
    //   - lastAuditDate: string (optional, ISO 8601)
    //   - nextAuditDate: string (optional, ISO 8601)
    //   - criticalIssues: number (optional)
    //
    // Collection: appointments
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - date: string (required, ISO 8601)
    //   - type: string (required, enum: VISITA, REUNIAO, REGULARIZACAO, AUDITORIA)
    //   - worksite: string (optional)
    //   - contractorId: string (optional)
    //   - description: string (optional)
    //   - status: string (required, enum: PLANEJADO, REALIZADO, CANCELADO)
    //   - createdBy: string (required, matches auth.uid)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "mcdonanzan@gmail.com";
    }

    function isEditor() {
      return isAuthenticated() && (request.auth.token.email == "mcdonanzan@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']));
    }

    match /snapshots/{snapshotId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (request.auth.token.email == "mcdonanzan@gmail.com" || isAdmin());
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEditor();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
        (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
    }
  }
}
